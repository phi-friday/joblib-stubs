{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--open-web-dashboard",
        "false"
      ],
      "enabled": true
    }
  },
  "lsp": {
    "pyrefly": {
      "command": [
        "uvx",
        "pyrefly",
        "lsp",
        "--color",
        "never"
      ],
      "extensions": [
        ".py",
        "pyi"
      ]
    },
    "pyright": {
      "disabled": true
    }
  }
}